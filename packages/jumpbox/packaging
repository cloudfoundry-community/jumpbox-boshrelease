#!/bin/bash
set -e # exit immediately if a simple command exits with a non-zero status
set -u # report the usage of uninitialized variables

# Detect # of CPUs so make jobs can be parallelized
CPUS=$(grep -c ^processor /proc/cpuinfo)
 # Available variables
# $BOSH_COMPILE_TARGET - where this package & spec'd source files are available
# $BOSH_INSTALL_TARGET - where you copy/install files to be included in package
export HOME=/var/vcap
n=0 # how many jobs have we spun in parallel?

cp -a jumpbox/setup ${BOSH_INSTALL_TARGET}/setup
chmod 0755 ${BOSH_INSTALL_TARGET}/setup

mkdir ${BOSH_INSTALL_TARGET}/bin
cp -a jumpbox/bins/* ${BOSH_INSTALL_TARGET}/bin
cp -a jumpbox/cloudfoundry-utils/* ${BOSH_INSTALL_TARGET}/bin
chmod 0755 ${BOSH_INSTALL_TARGET}/bin/*

# cf is the Cloud Foundry CLI v8; keep a cf8 alias for anything that still
# invokes the version-suffixed name (cf v6/v7 are no longer shipped).
ln -sf cf ${BOSH_INSTALL_TARGET}/bin/cf8

# GIT
# https://www.kernel.org/pub/software/scm/git
# https://www.kernel.org/pub/software/scm/git/git-2.54.0.tar.gz
(tar -xzvf jumpbox/git-2.54.0.tar.gz
 cd git-2.54.0
 ./configure --prefix=${BOSH_INSTALL_TARGET}
 make -j${CPUS} all
 make install) &
n=$((n + 1))

# TMUX
# http://libevent.org/
# https://github.com/libevent/libevent/releases/download/release-2.1.12-stable/libevent-2.1.12-stable.tar.gz
# https://tmux.github.io/
# https://github.com/tmux/tmux/releases/download/3.6b/tmux-3.6b.tar.gz
(tar -xzvf jumpbox/libevent-2.1.12-stable.tar.gz
 (cd libevent-2.1.12-stable
  ./configure --prefix=/usr --disable-shared
  make -j${CPUS}
  make install)

 tar -xzvf jumpbox/tmux-3.6b.tar.gz
 cd tmux-3.6b
 ./configure --prefix=${BOSH_INSTALL_TARGET} \
             --enable-static
 sed -i 's@#define TMUX_CONF.*@#define TMUX_CONF "'${BOSH_INSTALL_TARGET}'/etc/tmux.conf"@' tmux.h
 make -j${CPUS}
 make install) &
n=$((n + 1))

# TREE
# https://gitlab.com/OldManProgrammer/unix-tree
# https://gitlab.com/OldManProgrammer/unix-tree/-/archive/2.3.2/unix-tree-2.3.2.tar.gz
(tar -xzvf jumpbox/tree-2.3.2.tar.gz
 cd unix-tree-2.3.2
 sed -i "s|^PREFIX=.*|PREFIX=${BOSH_INSTALL_TARGET}|" Makefile
 make -j${CPUS}
 make install) &
n=$((n + 1))

# WGET
# http://ftp.gnu.org/gnu/wget/
# https://ftp.gnu.org/gnu/wget/wget-1.25.0.tar.gz
(tar -xzvf jumpbox/wget-1.25.0.tar.gz
 cd wget-1.25.0
 OPENSSL_CFLAGS=" " OPENSSL_LIBS="-lssl -lcrypto" ./configure --prefix=${BOSH_INSTALL_TARGET} --with-ssl=openssl
 make -j${CPUS}
 make install) &
n=$((n + 1))

# S3CMD
# https://github.com/s3tools/s3cmd/releases/download/v2.4.0/s3cmd-2.4.0.tar.gz
# Offline install using vendored wheels
# PIP_BREAK_SYSTEM_PACKAGES bypasses PEP-668 (externally-managed-environment),
# which the ubuntu-noble stemcell's system Python enforces; vendored pip is
# 25.0.1, which honors this env var (no-op on jammy's compile path).
(export PIP_BREAK_SYSTEM_PACKAGES=1
 python3 jumpbox/get-pip.py --no-index --find-links=jumpbox/wheels
 export PATH=$HOME/.local/bin:$PATH
 tar -xzvf jumpbox/s3cmd-2.4.0.tar.gz
 cd s3cmd-2.4.0
 pip install . --prefix=${BOSH_INSTALL_TARGET} \
   --no-index \
   --find-links=../jumpbox/wheels) &
n=$((n + 1))

while [[ $n -gt 0 ]]; do
	wait -n
	n=$((n - 1))
done

# VIM (prebuilt, repacked from vim/vim-appimage by ci/scripts/repack-vim-appimage)
# The vim binary's RUNPATH is '$ORIGIN/../lib', so bin/ and lib/ must stay
# siblings under vim/. Thin wrappers in bin/ export VIM + VIMRUNTIME so the
# bundled runtime files and the system vimrc resolve on the jumpbox.
tar -xzvf jumpbox/vim-9.2.0541-linux-amd64.tar.gz
mkdir -p ${BOSH_INSTALL_TARGET}/vim ${BOSH_INSTALL_TARGET}/bin ${BOSH_INSTALL_TARGET}/share/vim
cp -a vim/bin ${BOSH_INSTALL_TARGET}/vim/bin
cp -a vim/lib ${BOSH_INSTALL_TARGET}/vim/lib
cp -a vim/share/vim/vim[0-9]* ${BOSH_INSTALL_TARGET}/share/vim/
for tool in $(ls ${BOSH_INSTALL_TARGET}/vim/bin); do
  cat > ${BOSH_INSTALL_TARGET}/bin/${tool} <<WRAP
#!/bin/sh
here="\$(cd "\$(dirname "\$(readlink -f "\$0")")" && pwd)"
export VIM="\${here}/../share/vim"
export VIMRUNTIME="\$(echo "\${here}"/../share/vim/vim[0-9]*)"
# vim's bundled libs must win over the package-wide LD_LIBRARY_PATH set in bashrc
export LD_LIBRARY_PATH="\${here}/../vim/lib\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
exec "\${here}/../vim/bin/${tool}" "\$@"
WRAP
  chmod 0755 ${BOSH_INSTALL_TARGET}/bin/${tool}
done
ln -sf vim ${BOSH_INSTALL_TARGET}/bin/vi

cp jumpbox/vimrc     ${BOSH_INSTALL_TARGET}/share/vim/vimrc
cp jumpbox/tmux.conf ${BOSH_INSTALL_TARGET}/etc/tmux.conf
